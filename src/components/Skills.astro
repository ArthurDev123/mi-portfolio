---
interface SoftSkill {
  name: string;
}

interface HardSkill {
  name: string;
  level: "Bajo" | "Medio" | "Alto";
}

interface ExtraSkill {
  name: string;
  percentage: number;
  color?: string;
}

interface Props {
  softSkills: SoftSkill[];
  hardSkills: HardSkill[];
  extraSkills?: ExtraSkill[];
  lang?: string;
}

const { softSkills, hardSkills, extraSkills = [], lang = 'es' } = Astro.props;

const levelToPercentage = {
  "Bajo": 40,
  "Medio": 70,
  "Alto": 90,
};

// Mapeo de iconos para tecnologías
const techIcons: Record<string, string> = {
  "JavaScript": "https://cdn.simpleicons.org/javascript/F7DF1E",
  "TypeScript": "https://cdn.simpleicons.org/typescript/3178C6",
  "React": "https://cdn.simpleicons.org/react/61DAFB",
  "Node.js": "https://cdn.simpleicons.org/nodedotjs/339933",
  "MongoDB": "https://cdn.simpleicons.org/mongodb/47A248",
  "PostgreSQL": "https://cdn.simpleicons.org/postgresql/4169E1",
  "Firebase": "https://cdn.simpleicons.org/firebase/FFCA28",
  "Git": "https://cdn.simpleicons.org/git/F05032",
  "GitHub": "https://cdn.simpleicons.org/github/FFFFFF",
  "VS Code": "https://cdn.simpleicons.org/visualstudiocode/007ACC",
  "Postman": "https://cdn.simpleicons.org/postman/FF6C37",
  "Docker": "https://cdn.simpleicons.org/docker/2496ED",
  "HTML": "https://cdn.simpleicons.org/html5/E34C26",
  "CSS": "https://cdn.simpleicons.org/css3/1572B6",
  "SCSS": "https://cdn.simpleicons.org/sass/CC6699",
  "Python": "https://cdn.simpleicons.org/python/3776AB",
  "Astro": "https://cdn.simpleicons.org/astro/FF5D01",
  "Vue.js": "https://cdn.simpleicons.org/vuedotjs/4FC08D",
  "Tailwind CSS": "https://cdn.simpleicons.org/tailwindcss/06B6D4",
  "Next.js": "https://cdn.simpleicons.org/nextdotjs/FFFFFF",
  "Express": "https://cdn.simpleicons.org/express/FFFFFF",
  "Angular": "https://cdn.simpleicons.org/angular/DD0031",
  "SQL": "https://cdn.simpleicons.org/postgresql/336791"
};



const getIconUrl = (name: string): string | undefined => {
  return techIcons[name];
};

---

<section class="skills-section">
  <div class="skills-container">
    <div class="skill-category">
      <h3>Habilidades Blandas</h3>
      <div class="soft-skills-grid">
        {
          softSkills.map((skill) => (
            <span class="soft-skill-tag">
              <span>{skill.name}</span>
            </span>
          ))
        }
      </div>
    </div>

    {extraSkills.length > 0 && (
      <div class="skill-category">
        <h3>Proporciones</h3>
        <div class="pie-chart-container">
          <div class="pie-chart-wrapper">
            <svg viewBox="0 0 100 100" class="pie-chart-svg">
              {(() => {
                let cumulativePercent = 0;
                return extraSkills.map((skill) => {
                  const startAngle = (cumulativePercent / 100) * 2 * Math.PI;
                  cumulativePercent += skill.percentage;
                  const endAngle = (cumulativePercent / 100) * 2 * Math.PI;
                  
                  const x1 = 50 + 40 * Math.cos(startAngle - Math.PI / 2);
                  const y1 = 50 + 40 * Math.sin(startAngle - Math.PI / 2);
                  const x2 = 50 + 40 * Math.cos(endAngle - Math.PI / 2);
                  const y2 = 50 + 40 * Math.sin(endAngle - Math.PI / 2);
                  
                  const largeArcFlag = skill.percentage > 50 ? 1 : 0;
                  const pathData = `M 50 50 L ${x1} ${y1} A 40 40 0 ${largeArcFlag} 1 ${x2} ${y2} Z`;
                  
                  return (
                    <path 
                      class="pie-slice" 
                      d={pathData}
                      style={`fill: ${skill.color};`}
                    />
                  );
                });
              })()}
              <circle cx="50" cy="50" r="25" class="pie-hole" />
            </svg>
            <div class="pie-center">
              <span class="pie-label">100%</span>
            </div>
          </div>
          <div class="pie-legend">
            {extraSkills.map((skill) => (
              <div class="legend-item">
                <span class="legend-color" style={`background-color: ${skill.color};`}></span>
                <span class="legend-name">{skill.name}</span>
                <span class="legend-percent">{skill.percentage}%</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <div class="skill-category">
      <h3>Habilidades Técnicas</h3>
      <div class="skills-grid">
        {
          hardSkills.map((skill) => (
            <div class="skill-item">
              <div class="skill-header">
                <div class="skill-name-with-icon">
                  {getIconUrl(skill.name) && (
                    <img 
                      src={getIconUrl(skill.name)} 
                      alt={skill.name}
                      class="skill-icon"
                      title={skill.name}
                    />
                  )}
                  <span class="skill-name">{skill.name}</span>
                </div>
                <span class="skill-level">{skill.level}</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style={`width: ${levelToPercentage[skill.level]}%`}></div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    width: 100%;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .skills-container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    width: 100%;
    align-items: start;
  }

  .skill-category h3 {
    margin: 0 0 clamp(1.5rem, 2vw, 2rem) 0;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 600;
    color: var(--text-primary);
  }

  .soft-skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.6rem, 1.5vw, 1rem);
  }

  .soft-skill-tag {
    padding: clamp(0.5rem, 1vw, 0.7rem) clamp(1rem, 2vw, 1.4rem);
    background: rgba(120, 115, 245, 0.15);
    border: 1px solid rgba(120, 115, 245, 0.4);
    border-radius: clamp(0.4rem, 0.8vw, 0.6rem);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 500;
    color: var(--text-primary);
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .soft-skill-icon {
    width: clamp(1rem, 1.8vw, 1.3rem);
    height: clamp(1rem, 1.8vw, 1.3rem);
    object-fit: contain;
    filter: drop-shadow(0 0 3px rgba(120, 115, 245, 0.4));
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .soft-skill-tag:hover .soft-skill-icon {
    filter: drop-shadow(0 0 6px rgba(0, 240, 255, 0.6));
    transform: scale(1.15);
  }

  .soft-skill-tag:hover {
    background: rgba(120, 115, 245, 0.3);
    border-color: rgba(120, 115, 245, 0.7);
    box-shadow: 0 0 10px rgba(120, 115, 245, 0.3);
    transform: translateY(-2px);
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2vw, 1.8rem);
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .skill-name {
    font-size: clamp(0.875rem, 2vw, 1rem);
    font-weight: 500;
    color: var(--text-primary);
  }

  .skill-name-with-icon {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .skill-icon {
    width: clamp(1.2rem, 2vw, 1.5rem);
    height: clamp(1.2rem, 2vw, 1.5rem);
    object-fit: contain;
    filter: drop-shadow(0 0 4px rgba(120, 115, 245, 0.4));
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .skill-item:hover .skill-icon {
    filter: drop-shadow(0 0 8px rgba(0, 240, 255, 0.6));
    transform: scale(1.1);
  }

  .skill-level {
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    font-weight: 600;
    color: var(--accent-light);
  }

  .skill-bar {
    width: 100%;
    height: clamp(6px, 1vw, 10px);
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, #7873f5, #00f0ff);
    border-radius: 10px;
    transition: width 0.6s ease;
    box-shadow: 0 0 10px rgba(120, 115, 245, 0.5);
  }

  .pie-chart-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .pie-chart-wrapper {
    position: relative;
    width: clamp(180px, 30vw, 220px);
    height: clamp(180px, 30vw, 220px);
  }

  .pie-chart-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    filter: drop-shadow(0 0 10px rgba(120, 115, 245, 0.3));
  }

  .pie-slice {
    transition: transform 0.2s ease, filter 0.2s ease, opacity 0.2s ease;
    cursor: pointer;
    transform-origin: center;
  }

  .pie-slice:hover {
    transform: scale(1.05);
    filter: drop-shadow(0 0 8px currentColor);
    opacity: 0.9;
  }

  .pie-hole {
    fill: var(--bg-primary);
  }

  .pie-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50%;
    height: 50%;
    background: var(--bg-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .pie-label {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: bold;
    color: var(--text-primary);
  }

  .pie-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem 1.5rem;
    width: 100%;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(0.7rem, 1.3vw, 0.9rem);
  }

  .legend-color {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .legend-name {
    color: var(--text-primary);
  }

  .legend-percent {
    color: var(--text-secondary);
    font-weight: 600;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .skills-container {
      grid-template-columns: 1fr 1fr;
      gap: clamp(1.5rem, 3vw, 2rem);
    }
  }

  @media (max-width: 600px) {
    .skills-container {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 3vw, 2rem);
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .skills-section {
      padding: clamp(0.75rem, 2vw, 1.5rem);
    }

    .skill-category h3 {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
    }

    .skills-grid {
      gap: clamp(1rem, 1.5vw, 1.5rem);
    }

    .soft-skill-tag {
      font-size: clamp(0.7rem, 1.2vw, 0.85rem);
    }
  }
</style>
